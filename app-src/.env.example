# ── NextAuth ─────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://YOUR_EC2_IP:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Google OAuth ──────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Google Service Account (for Drive access) ─────────────────────────────
# Create a Service Account in Google Cloud, download JSON key
GOOGLE_SERVICE_ACCOUNT_EMAIL=gbl-cff@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# ── Google Drive ──────────────────────────────────────────────────────────
# The folder ID from the Drive URL: drive.google.com/drive/folders/FOLDER_ID
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# ── Gmail Notifications ───────────────────────────────────────────────────
# Use a Gmail App Password (not your real password)
# Google Account → Security → 2FA → App Passwords
GMAIL_USER=finance@goatbrandlabs.com
GMAIL_APP_PASSWORD=your-16-char-app-password
